    "info": {
        "name": "CAA \u2014 API Documentation",
        "_postman_id": "7358fb52-8a6a-47dd-97c7-f157d759c302",
        "description": "API REST de la plateforme CAA (Certificat Authenticit\u00e9 Artiste) \u2014 gestion des artistes, \u0153uvres, certificats num\u00e9riques et v\u00e9rification publique.",
