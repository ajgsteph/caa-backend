                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"all_devices\":false}"
                        },
                        "description": "R\u00e9voque le token courant. Passez `all_devices=true` pour r\u00e9voquer tous les tokens."
                    },
