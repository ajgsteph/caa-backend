    },
    "item": [
        {
            "name": "Authentication",
            "description": "\nEndpoints d'inscription, connexion et d\u00e9connexion. Les tokens sont \u00e9mis par Sanctum.",
            "item": [
                {
                    "name": "Inscription d'un artiste",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/register",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/auth\/register"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"last_name\":\"b\",\"first_name\":\"n\",\"artist_name\":\"g\",\"email\":\"rowan.gulgowski@example.com\",\"password\":\"architecto\",\"phone\":\"n\"}"
                        },
                        "description": "Cr\u00e9e un compte artiste, l'attache au r\u00f4le `artist` et retourne un token Sanctum.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 201,
                            "body": "{\n  \"data\": {\n    \"id\": 5,\n    \"last_name\": \"Diop\",\n    \"first_name\": \"Awa\",\n    \"artist_name\": \"AWA-D\",\n    \"email\": \"awa@test.sn\",\n    \"phone\": \"+221770000000\",\n    \"status\": \"ACTIVE\",\n    \"registered_at\": \"2026-04-25T22:14:23+00:00\",\n    \"roles\": [\"artist\"]\n  },\n  \"token\": \"5|h6uDj3r2qZr87yKofZNmjXbaz3S3JyWcxXe4j5Eyf9f4fce1\"\n}",
                            "name": "success"
                        }
                    ]
                },
                {
                    "name": "Connexion",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/login",
                            "query": [],
                            "raw": "{{baseUrl}}\/api\/v1\/auth\/login"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"gbailey@example.net\",\"password\":\"|]|{+-\",\"device_name\":\"v\"}"
                        },
                        "description": "Authentifie un utilisateur et retourne un token Sanctum.",
                        "auth": {
                            "type": "noauth"
                        }
                    },
                    "response": [
                        {
                            "header": [],
                            "code": 200,
                            "body": "{\n  \"data\": {\"id\": 3, \"email\": \"awa@caa.sn\", \"roles\": [\"artist\"]},\n  \"token\": \"2|6URd4kiuvxY5pHKFzSnpYbP0LM3XkLattT2rTfCze475f5bb\"\n}",
                            "name": "success"
