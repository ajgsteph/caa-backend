                        {
                            "header": [],
                            "code": 422,
                            "body": "{\n  \"message\": \"Identifiants invalides.\",\n  \"errors\": {\"email\": [\"Identifiants invalides.\"]}\n}",
                            "name": "invalid credentials"
                        }
                    ]
                },
                {
                    "name": "D\u00e9connexion",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/auth\/logout",
