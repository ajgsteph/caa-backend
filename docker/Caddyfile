{
    {$CADDY_GLOBAL_OPTIONS}

    # Render terminates TLS at the edge — serve plain HTTP inside the container.
    auto_https off

    frankenphp {
        {$FRANKENPHP_CONFIG}
    }
}

{$CADDY_EXTRA_CONFIG}

:{$PORT:80} {
    log {
        output stderr
        format console
        {$CADDY_SERVER_LOG_OPTIONS}
    }

    root * /app/public
    encode zstd br gzip

    {$CADDY_SERVER_EXTRA_DIRECTIVES}

    # Laravel front controller — every non-file request is sent to public/index.php.
    php_server
}
